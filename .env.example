# =========================================
# Agentic RAG Compliance Assistant - config
# Copy this file to `.env` and adjust values.
#
# The defaults below match the profile used to produce the committed
# evaluation runs (`reports/eval_aya8b.csv` and
# `reports/eval_aya8b_hybrid_smoke.csv`). Override any value to swap
# in a different model / mode without code changes.
# =========================================

# --- LLM provider ---
# One of: "ollama", "dummy"
LLM_PROVIDER=ollama

# Ollama settings (only used if LLM_PROVIDER=ollama)
# When running outside Docker, use http://localhost:11434.
OLLAMA_BASE_URL=http://ollama:11434

# Main answer-generation model. Pick the largest one your box can
# still keep loaded; `aya-expanse:8b` runs on 16 GB RAM CPU-only and
# was used for the committed eval. Alternatives: qwen2.5:14b-instruct
# (better quality, needs >16 GB), mistral-nemo:12b.
OLLAMA_MODEL=aya-expanse:8b

# Embedding model. bge-m3 is 1024-dim, multilingual, ~600 MB.
OLLAMA_EMBEDDING_MODEL=bge-m3

# Lightweight model for classifier / decomposer / RAG grader. The 0.6 B
# qwen3 is fast enough on CPU that it does not dominate latency.
OLLAMA_FAST_MODEL=qwen3:0.6b

# Independent judge model for LLM-as-judge evaluation. Using a different
# model from the main one avoids self-bias. The same lightweight qwen3
# also works well as judge.
OLLAMA_JUDGE_MODEL=qwen3:0.6b

# Generation params. 400 tokens is enough for cited TAO answers and
# keeps per-call latency low on CPU.
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=400

# Not read by this app, but recommended on the Ollama daemon side so
# the model is not unloaded between requests during long eval runs:
#   $env:OLLAMA_KEEP_ALIVE = "24h"

# --- RAG / vector store ---
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION=compliance_docs
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
# Top-K 3 keeps the prompt small enough for the 8B model to stay
# coherent; raise to 5-8 on a larger model.
RAG_TOP_K=3
# Retrieval strategy: dense (default, backward compatible), bm25, or
# hybrid (Reciprocal Rank Fusion of both). Set to "hybrid" to use the
# new BM25 + dense pipeline; remember to build the BM25 index first
# via `python -m app.rag.ingestion --bm25-only`.
RAG_RETRIEVAL_MODE=dense
RAG_BM25_PATH=./data/chroma/bm25.pkl
RAG_RRF_K=60

# --- Agent workflow ---
# 0 = single answer attempt (matches the committed eval profile).
# Raise to 2 if you want the hallucination checker to drive retries.
MAX_HALLUCINATION_RETRIES=0

# --- Data ---
DOCUMENTS_DIR=./data/documents

# --- UI ---
STREAMLIT_SERVER_PORT=8501

# --- Logging ---
LOG_LEVEL=INFO
