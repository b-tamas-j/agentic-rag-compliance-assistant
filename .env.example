# =========================================
# Agentic RAG Compliance Assistant - config
# Copy this file to `.env` and adjust values.
# =========================================

# --- LLM provider ---
# One of: "ollama", "dummy"
LLM_PROVIDER=ollama

# Ollama settings (only used if LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:14b-instruct
OLLAMA_EMBEDDING_MODEL=bge-m3
# Independent judge model for LLM-as-judge evaluation (avoid self-bias).
OLLAMA_JUDGE_MODEL=mistral-nemo:12b
# Smaller / faster model used for load testing.
OLLAMA_FAST_MODEL=aya-expanse:8b

# Generation params
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024

# --- RAG / vector store ---
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION=compliance_docs
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=5
# Retrieval strategy: dense (default), bm25, or hybrid (RRF of both).
RAG_RETRIEVAL_MODE=dense
RAG_BM25_PATH=./data/chroma/bm25.pkl
RAG_RRF_K=60

# --- Agent workflow ---
MAX_HALLUCINATION_RETRIES=2

# --- Data ---
DOCUMENTS_DIR=./data/documents

# --- UI ---
STREAMLIT_SERVER_PORT=8501

# --- Logging ---
LOG_LEVEL=INFO
